APP_NAME="سهل"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ===== قاعدة البيانات =====
# الوضع الافتراضي SQLite للتشغيل الفوري بدون أي إعداد.
# للتحويل إلى MySQL: فعّل الأسطر أدناه واضبط القيم.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=aqar
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

# sync = تُرسَل الإشعارات البريدية فوراً دون الحاجة لمشغّل طابور
QUEUE_CONNECTION=sync
CACHE_STORE=database
FILESYSTEM_DISK=local

# log = تُسجَّل رسائل البريد في storage/logs/laravel.log (مناسب للتجربة)
# للإرسال الفعلي غيّر MAIL_MAILER=smtp واضبط بيانات الخادم
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@aqar.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
